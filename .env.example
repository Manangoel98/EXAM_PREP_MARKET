# Marketing Site Configuration

# Required: this marketing site’s public origin (canonical, OG, sitemap, robots).
NEXT_PUBLIC_BASE_URL=https://nomoexam.com

# Required: student app origin (CTAs, proxy redirects to app — never use for marketing canonical URLs).
NEXT_PUBLIC_APP_URL=https://app.nomoexam.com

# API URL (for contact forms only - optional)
# NEXT_PUBLIC_API_URL=https://api.nomoexam.com

# SEO & Verification (Optional but recommended for production)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_google_verification_code_here
# Get this from: https://search.google.com/search-console/ownership

# Additional SEO services (optional)
# NEXT_PUBLIC_BING_VERIFICATION=your_bing_verification_code
# NEXT_PUBLIC_YANDEX_VERIFICATION=your_yandex_verification_code

# Web Bot Auth (optional): override JWKS served at /.well-known/http-message-signatures-directory
# Default is lib/http-message-signatures-directory.jwks.json. Generate new keys:
#   pnpm run generate:web-bot-auth-jwks
# @see https://datatracker.ietf.org/wg/webbotauth/about/
# WEB_BOT_AUTH_JWKS_JSON={"keys":[{"kty":"OKP","crv":"Ed25519","x":"..."}]}
